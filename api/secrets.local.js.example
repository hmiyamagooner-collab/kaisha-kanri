/**
 * OpenAI APIキー（ローカル・手動設定用）
 *
 * 手順:
 *   1. このファイルを同じフォルダに secrets.local.js としてコピー
 *   2. 下の OPENAI_API_KEY に sk-... を貼り付けて保存
 *
 * secrets.local.js は git に含めません（.gitignore 済み）。
 * Vercel 本番では Dashboard → Settings → Environment Variables の
 * OPENAI_API_KEY が優先されます。
 */
export default {
  OPENAI_API_KEY: "sk-ここにOpenAIのAPIキーを貼り付け",

  // Google Sheets（CF同期）— サービスアカウントの JSON から転記
  // 1) Google Cloud でサービスアカウント作成 → JSONキー発行
  // 2) スプシをその client_email に「閲覧者」で共有
  // 3) 下を埋める（private_key の改行は \n のままでOK）
  GOOGLE_SERVICE_ACCOUNT_EMAIL: "xxxxx@xxxxx.iam.gserviceaccount.com",
  GOOGLE_PRIVATE_KEY: "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
  GOOGLE_SHEETS_SPREADSHEET_ID: "1d1LEQ_Mfjqm43r9wLkrqtsbdqWLl9Iyd7bgL6PATxUs",
  GOOGLE_SHEETS_GID: "1995516463",
};
