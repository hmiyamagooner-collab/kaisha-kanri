/**
 * OpenAI APIキー（ローカル・手動設定用）
 *
 * 手順:
 *   1. このファイルを同じフォルダに secrets.local.js としてコピー
 *   2. 下の OPENAI_API_KEY に sk-... を貼り付けて保存
 *
 * secrets.local.js は git に含めません（.gitignore 済み）。
 * Vercel 本番では Dashboard → Settings → Environment Variables の
 * OPENAI_API_KEY が優先されます。
 *
 * 出勤督促メール（任意）:
 *   RESEND_API_KEY / ATTENDANCE_FROM / CRON_SECRET / SUPABASE_SERVICE_ROLE_KEY
 */
export default {
  OPENAI_API_KEY: "sk-ここにOpenAIのAPIキーを貼り付け",
  // CFのPDF取込も同じキーを使います（/api/pdf-cf）
};
