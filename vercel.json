{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/pdf-cf.js": { "maxDuration": 60 },
    "api/openai.js": { "maxDuration": 60 },
    "api/whisper-minutes.js": { "maxDuration": 60 },
    "api/dropbox-sync.js": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/attendance-remind",
      "schedule": "30 0 * * 1-5"
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
